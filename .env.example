# PKI CLI Configuration
# Copy this file to .env and fill in your values
# Or copy to ~/.config/pki-cli/.env for global configuration

# PKI Manager API URL (required)
PKI_API_URL=https://your-pki-server.example.com/api/v1

# OIDC Token Endpoint (required)
PKI_OIDC_URL=https://your-iam-server.example.com/realms/your-realm/protocol/openid-connect/token

# OIDC Client Credentials (required)
PKI_CLIENT_ID=your-client-id
PKI_CLIENT_SECRET=your-client-secret

# Optional bearer tokens for the machine-facing `pki external` commands
# (these bypass OIDC and carry their own token):
#   PKI_CLUSTER_TOKEN — cluster token (pkimg_...) for the X.509 issuer API
#   PKI_FLEET_TOKEN   — fleet token for the SSH automation API
# PKI_CLUSTER_TOKEN=pkimg_...
# PKI_FLEET_TOKEN=...
